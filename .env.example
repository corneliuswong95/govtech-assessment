# Environment Configuration Template
# Copy this to .env and update with your values

# Application Environment
NODE_ENV=development

# Server
PORT=3000
HOST=localhost

# Storage Mode
# Options: 'local' (for development/testing), 'dynamo' (for production)
STORAGE_MODE=local

# Local Storage
REDEMPTIONS_FILE_PATH=./data/redemptions.json

# DynamoDB Configuration (required if STORAGE_MODE=dynamo)
DYNAMO_TABLE=redemptions
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>

# Staff Data
STAFF_CSV_PATH=./data/staff.csv

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=100
RETRY_MAX_DELAY_MS=5000
RETRY_BACKOFF_MULTIPLIER=2
